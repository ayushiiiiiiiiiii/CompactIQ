# AI Integration (REQUIRED for chat to work)
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration (Defaults to SQLite if not provided or set to true)
USE_SQLITE=true
# POSTGRES_SERVER=localhost
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=compliance_engine
# POSTGRES_PORT=5432

# Redis (If you ever add celery/background tasks)
REDIS_URL=redis://localhost:6379/0

# Security (Used for Knowledge Base Admin to delete docs / flush DB)
ADMIN_MAINTENANCE_PASSWORD=admin123
